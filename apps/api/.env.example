# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/applyflow

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-long-random-secret

# Token lifetime in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Web app ───────────────────────────────────────────────────────────────────
# Used for CORS and SSO redirects — must match where the web app is hosted
WEB_APP_URL=http://localhost:3000

# Extra CORS origins (comma-separated) if needed beyond WEB_APP_URL
# CORS_ORIGINS=["https://app.yourdomain.com","https://yourdomain.com"]

# ── AI Models ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Sonnet — used for resume tailoring, complex analysis
DEFAULT_AI_MODEL=claude-sonnet-4-6

# Haiku — used for field answering, match scoring (fast + cheap)
FAST_AI_MODEL=claude-haiku-4-5-20251001

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Webhook secret — set in Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=...
# Plan IDs — create plans in Dashboard → Subscriptions → Plans
RAZORPAY_MONTHLY_PLAN_ID=plan_...
RAZORPAY_ANNUAL_PLAN_ID=plan_...
