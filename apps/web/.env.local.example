# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of the ApplyFlow API server (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (used for real-time features)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Web app ───────────────────────────────────────────────────────────────────
# Public URL of this web app — used for SSO deep-links and CORS
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Key ID only (public — safe to expose). Key Secret stays in the API .env
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
